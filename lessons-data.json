    {
      "id": "lesson1q",
      "title": "be動詞の基本 演習",
      "steps": [
        {
          "type": "question",
          "question": "be動詞の意味は何？",
          "subText": "am・is・are に共通する、たった1つの意味を選ぼう",
          "choices": [
            "〜する\\n（動作）",
            "＝（イコール）\\n（A は B だ）",
            "〜できる\\n（可能）",
            "〜だった\\n（過去）"
          ],
          "answer": 1,
          "explanation": "be動詞の意味は「＝（イコール）」のたった1つだけです。",
          "wrongExplanation": "be動詞の意味は「＝（イコール）」だけです。スライドをもう一度確認してみよう。"
        }
      ]
    },
    {
      "id": "lesson2q",
      "title": "be動詞の種類 演習",
      "steps": [
        {
          "type": "question",
          "question": "主語が「I」のとき、be動詞は何？",
          "subText": "対応表を思い出して選ぼう",
          "choices": [
            "is",
            "am",
            "are",
            "be"
          ],
          "answer": 1,
          "explanation": "主語が I のとき、be動詞は am です。"
        },
        {
          "type": "question",
          "question": "主語が「She」のとき、be動詞は何？",
          "subText": "対応表を思い出して選ぼう",
          "choices": [
            "am",
            "are",
            "is",
            "be"
          ],
          "answer": 2,
          "explanation": "主語が She のとき、be動詞は is です。"
        },
        {
          "type": "question",
          "question": "主語が「They」のとき、be動詞は何？",
          "subText": "対応表を思い出して選ぼう",
          "choices": [
            "am",
            "is",
            "are",
            "be"
          ],
          "answer": 2,
          "explanation": "主語が They のとき、be動詞は are です。"
        },
        {
          "type": "question",
          "question": "（　）に入るbe動詞はどれ？",
          "subText": "主語を確認してから選ぼう",
          "sentence": "He ___ my friend.",
          "choices": [
            "am",
            "is",
            "are",
            "be"
          ],
          "answer": 1,
          "explanation": "主語が He なので be動詞は is です。"
        },
        {
          "type": "question",
          "question": "（　）に入るbe動詞はどれ？",
          "subText": "主語を確認してから選ぼう",
          "sentence": "We ___ classmates.",
          "choices": [
            "am",
            "is",
            "are",
            "be"
          ],
          "answer": 2,
          "explanation": "主語が We なので be動詞は are です。"
        }
      ]
    },
    {
      "id": "lesson3q",
      "title": "be動詞の否定文 演習",
      "steps": [
        {
          "type": "question",
          "question": "be動詞の否定文の作り方は？",
          "subText": "正しいルールを選ぼう",
          "choices": [
            "be動詞の前にnotを置く",
            "be動詞の後ろにnotを置く",
            "文の末尾にnotを置く",
            "notをbe動詞に変える"
          ],
          "answer": 1,
          "explanation": "be動詞の後ろに not を置きます。例：He is not happy.",
          "wrongExplanation": "not は be動詞の後ろに置きます（前ではありません）。例：He is not happy."
        },
        {
          "type": "question",
          "question": "次の肯定文を否定文にすると？",
          "subText": "「She is busy.」→ 否定文はどれ？",
          "choices": [
            "She not is busy.",
            "She is not busy.",
            "Not she is busy.",
            "She is busy not."
          ],
          "answer": 1,
          "explanation": "be動詞（is）の後ろに not を置きます。She is not busy.",
          "wrongExplanation": "not は be動詞の後ろです。She is not busy. が正解。"
        },
        {
          "type": "question",
          "question": "（　）に入る語はどれ？",
          "subText": "正しい語順を選ぼう",
          "sentence": "I am ___ a student.",
          "choices": [
            "no",
            "don't",
            "not",
            "isn't"
          ],
          "answer": 2,
          "explanation": "be動詞（am）の後ろに not を置きます。I am not a student.",
          "wrongExplanation": "be動詞の否定は not を使います。I am not a student."
        }
      ]
    },
    {
      "id": "lesson6q",
      "title": "be動詞II｜be動詞の疑問文 演習",
      "steps": [
        {
          "type": "question",
          "question": "正しい疑問文はどれ？",
          "subText": "次の文を疑問文にしよう",
          "sentence": "He is your friend.",
          "choices": [
            "He is your friend?",
            "Your friend is he?",
            "Is he your friend?"
          ],
          "answer": 2,
          "explanation": "be動詞 is を文頭に出して、Is he your friend? とします。",
          "wrongExplanation": "be動詞を文頭に出すのがルールです。正しくは Is he your friend?"
        },
        {
          "type": "question",
          "question": "「Yes」で答えるとき、正しいのはどれ？",
          "subText": "答え方に注目して選ぼう",
          "sentence": "Are you a student?",
          "choices": [
            "Yes, I'm.",
            "Yes, I am.",
            "Yes, am I."
          ],
          "answer": 1,
          "explanation": "Yes の答えは「主語 + be動詞」の形で、Yes, I am. が正解です。",
          "wrongExplanation": "「Yes, I am.」と「主語 + be動詞」で答えます。"
        },
        {
          "type": "question",
          "question": "（　）に入るbe動詞を選ぼう",
          "subText": "疑問文の語順と主語に注目",
          "sentence": "___ she happy?",
          "choices": [
            "Am",
            "Is",
            "Are",
            "Be"
          ],
          "answer": 1,
          "explanation": "主語が she なので be動詞は is。疑問文なので Is she happy? となります。",
          "wrongExplanation": "she に対応するbe動詞は is。正しくは Is she happy?"
        },
        {
          "type": "question",
          "question": "「No」で答えるとき、正しいのはどれ？",
          "subText": "答え方に注目して選ぼう",
          "sentence": "Is he your teacher?",
          "choices": [
            "No, he not.",
            "No, is he not.",
            "No, he isn't."
          ],
          "answer": 2,
          "explanation": "No の答えは「主語 + be動詞 + not」の形で、No, he isn't. が正解です。",
          "wrongExplanation": "「No, he isn't.」と「主語 + be動詞 + not」の形で答えます。"
        },
        {
          "type": "question",
          "question": "正しい疑問文はどれ？",
          "subText": "次の文を疑問文にしよう",
          "sentence": "They are students.",
          "choices": [
            "They are students?",
            "Are they students?",
            "Is they students?"
          ],
          "answer": 1,
          "explanation": "be動詞 are を文頭に出して、Are they students? とします。",
          "wrongExplanation": "be動詞を文頭に出すのがルールです。正しくは Are they students?"
        }
      ]
    },
